# packages/mobile — Expo client env. Copy to `.env` and fill in the values.
# Only EXPO_PUBLIC_* vars are exposed to the bundle (inlined at build time).
# Restart Metro with `--clear` after changing any of these.

# Clerk publishable key (public, client-side) — required for sign-in.
# From your Clerk instance dashboard; starts with pk_test_ (dev) or pk_live_ (prod).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_Y2xlcmsucG9ydGFibGUuZGV2JA"

# OAuth gateway base URL — sign-in exchange / provisioning / token refresh.
# OPTIONAL since #1384: unset, prod mode targets https://app.portable.dev.
# Local full-stack: http://localhost:3501 (run `bun gateway:dev`; the iOS simulator
# reaches the host Mac as localhost). Deployed dev gateway: https://app.portable-dev.com
EXPO_PUBLIC_GATEWAY_URL="https://app.portable.dev"

# ── Hidden dev mode (#1384) — tap the sign-in brand header 10× to toggle ──
# While dev mode is ON the app targets the dev gateway + dev Clerk instance.
# Both are OPTIONAL overrides; the defaults are the deployed dev environment.
# Dev-mode gateway (default: https://app.portable-dev.com).
EXPO_PUBLIC_GATEWAY_URL_DEV="https://app.portable-dev.com"
# Dev-mode Clerk publishable key (default: falls back to the main key above).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY_DEV="pk_test_cmVmaW5lZC1hbnRlbG9wZS0yMy5jbGVyay5hY2NvdW50cy5kZXYk"

# ── GitHub App install slug (#1376 "Configure permissions") — dev-mode-aware ──
# OPTIONAL overrides; usually leave BOTH unset. The defaults already pair the
# slug with the active gateway: prod mode → portable-app, dev mode → portable-dev-dev.
# (A mismatched pair stores the GitHub connection in the OTHER environment.)
EXPO_PUBLIC_GITHUB_APP_NAME=
EXPO_PUBLIC_GITHUB_APP_NAME_DEV=

# ── Sentry error monitoring (#1394) — ALL OPTIONAL for normal dev ──
# Sentry is AUTOMATIC in release builds (TestFlight/Play) using a bundled public
# DSN — you do NOT need to set anything here to ship with crash reporting. In a
# plain `expo start` / debug build Sentry stays OFF (so dev errors don't flood it).
#
# Set this ONLY if you want to verify Sentry on a LOCAL debug build via the hidden
# dev-mode "Sentry Test" page (Profile → Sentry Test, after the 10-tap dev mode):
# it turns Sentry ON in a dev build so the test buttons actually send events.
# EXPO_PUBLIC_ENABLE_SENTRY_TEST=true
#
# OPTIONAL: override the bundled public DSN (point at a different Sentry project).
# Get it from Sentry → Project Settings → Client Keys (DSN). Public, safe to bundle.
# EXPO_PUBLIC_SENTRY_DSN=
#
# OPTIONAL: event environment bucket (defaults to the platform: ios | android).
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=
#
# Source-map upload (symbolicated stack traces) is handled AUTOMATICALLY by CI
# (release-mobile.yml writes it from the repo SENTRY_AUTH_TOKEN secret). It does
# NOT belong in this file. To upload maps from a LOCAL native build instead, create
# `packages/mobile/.env.sentry-build-plugin` (git-ignored) with:
# SENTRY_AUTH_TOKEN=<oliver-volter-maybe org token, source-map scope>
# SENTRY_ORG=oliver-volter-maybe
# SENTRY_PROJECT=4511016585199616
# then run `expo run:ios` / `eas build --local`. (org/project also come from app.json.)
EXPO_PUBLIC_SENTRY_DSN=https://3698ef423005e5ccbcdda38f9d30795f@o4507742853070848.ingest.us.sentry.io/4511016585199616
