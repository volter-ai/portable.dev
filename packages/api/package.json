{
  "name": "@vgit2/api",
  "private": true,
  "version": "3.5.1",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env ../../scripts/write-backend-start-metadata.ts && bun --env-file=../../.env src/server.ts",
    "dev:watch": "bun --env-file=../../.env ../../scripts/write-backend-start-metadata.ts && bun --env-file=../../.env --watch src/server.ts",
    "dev:node": "node --import tsx --watch src/server.ts",
    "build": "tsc",
    "start": "bun src/server.ts",
    "start:node": "node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "bun test",
    "test:unit": "bun test src/**/__tests__/**",
    "test:integration": "bun test tests/integration",
    "test:watch": "bun test --watch",
    "test:ci": "bun test --bail"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.170",
    "@anthropic-ai/sdk": "^0.104.1",
    "@clerk/backend": "^2.29.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/plugin-retry": "^7",
    "@octokit/plugin-throttling": "^9",
    "@octokit/rest": "^21.0.2",
    "@playwright/mcp": "^0.0.54",
    "@playwright/test": "^1.56.0",
    "@sentry/node": "^10.42.0",
    "@slack/types": "^2.19.0",
    "@slack/web-api": "^7.13.0",
    "@vgit2/shared": "workspace:*",
    "apify-client": "^2.21.0",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "fs-extra": "^11.3.2",
    "http-proxy-middleware": "^3.0.5",
    "ignore": "^7.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "openai": "^6.2.0",
    "playwright": "^1.56.1",
    "replicate": "^1.2.0",
    "sharp": "^0.34.5",
    "sodium-native": "^4.3.2",
    "unique-names-generator": "^4.7.1",
    "uuid": "^11.0.4",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/sodium-native": "^2.3.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  }
}
