{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@vgit2/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts", "tests/**/*", "../../worktree/**"]
}
