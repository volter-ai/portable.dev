{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@vgit2/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["src/**/*.test.ts", "tests/**/*", "../../worktree/**", "../../.worktrees/**"]
}
