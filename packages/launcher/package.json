{
  "name": "@vgit2/launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "portable — local-first launcher / tunnel-router for the PC runtime (US-E3-001)",
  "bin": {
    "portable": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts start",
    "preview": "bun scripts/preview.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "bun test"
  },
  "dependencies": {
    "@vgit2/shared": "workspace:*",
    "cloudflared": "^0.7.1",
    "dotenv": "^17.2.3",
    "ink": "^6",
    "qrcode": "^1.5",
    "react": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5",
    "@types/react": "~19.2.2",
    "typescript": "^5.7.2"
  }
}
